rules_version = '2';

// AFFINITY — Cloud Storage Security Rules (v0 — minimal hardening)

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }

    function under5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function under50MB() {
      return request.resource.size < 50 * 1024 * 1024;
    }

    // ── Couple photos (legacy `profiles/` path + new `couples/` path) ────────
    match /profiles/{uid}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid) && isImage() && under5MB();
      allow delete: if isOwner(uid);
    }

    match /couples/{coupleId}/photos/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(coupleId) && isImage() && under5MB();
      allow delete: if isOwner(coupleId);
    }

    // ── Verification videos (Week 2) ─────────────────────────────────────────
    match /verifications/{coupleId}/{fileName} {
      // Only owner can upload; only Cloud Functions can read after upload
      // (moderators access via signed URLs generated by Cloud Function).
      allow read: if false;
      allow write: if isOwner(coupleId) && isVideo() && under50MB();
      allow delete: if false; // Cloud Function deletes after 7 days
    }

    // ── Verification frames (permanent record after video deletion) ──────────
    match /verification_frames/{coupleId}/{fileName} {
      allow read: if false;
      allow write: if false; // Cloud Function only
    }

    // ── Report evidence screenshots (Week 2) ─────────────────────────────────
    match /report_evidence/{reportId}/{fileName} {
      allow read: if false;
      allow create: if isAuthenticated() && isImage() && under5MB();
      allow update, delete: if false;
    }

    // ── Default deny ─────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
