.claude
CLAUDE.md

# Figma raw exports + thumbnails — work-in-progress only.
# The processed master assets in assets/branding/*.png and
# assets/branding/screenshots/{es,en}/ are committed; the raw
# multi-MB Figma frames used to produce them are not.
assets/branding/source/

# Secrets — private repo, temporarily included for CI build
# lib/core/config/api_keys.dart
# android/app/google-services.json
# android/app/google-services.production.json
# ios/Runner/GoogleService-Info.plist
# ios/Runner/GoogleService-Info.production.plist
.env
.env.*
!.env.example

# Apple Sign-In private signing keys (.p8). These are issued per-account
# from Apple Developer and grant the holder the ability to mint JWTs as
# our app's Apple Sign-In service — they MUST NEVER be committed even
# inside a private repo. The Key ID lives in the filename so the
# pattern below catches every name shape (AuthKey_*.p8 or just *.p8).
AuthKey_*.p8
*.p8

# Service-account keys that may end up dropped into the project root
# during local debugging — same rule, never commit.
sa-key-*.json
*-sa-key.json

# Firebase Functions build artefacts
functions/node_modules/
functions/lib/
functions/.eslintcache

# Firebase emulator data
.firebase/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*

# Service-account credentials — never commit
sa-key.json
*.key.json
sa-key-*.json

# Functions secrets for the emulator (real keys live in Secret Manager,
# never on disk in production)
functions/.secret.local
functions/.runtimeconfig.json

# One-off build logs (each run produces fresh ones)
build_log.txt
web_build_log*.txt

# Old APK + screenshots from before the current panel + tone-pass
# rounds. Kept locally for reference, never pushed.
"new version/"

# Random downloads that landed in the repo root by accident
tratamiento_*.png
